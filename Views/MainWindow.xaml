<Window x:Class="GasDistributionOptimizer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Оптимизация распределения природного газа" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignDefaultFont}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Параметры доменных печей" FontSize="24" FontWeight="Bold" Margin="0,0,0,16"/>

        <DataGrid Grid.Row="1" 
          ItemsSource="{Binding Furnaces}" 
          SelectedItem="{Binding SelectedFurnace}"
          AutoGenerateColumns="False" 
          CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="№" Binding="{Binding Id}" IsReadOnly="True" Width="60"/>

                <DataGridTextColumn Header="ПГ баз." Binding="{Binding BaseNaturalGas}"/>
                <DataGridTextColumn Header="ПГ мин." Binding="{Binding MinNaturalGas}"/>
                <DataGridTextColumn Header="ПГ макс." Binding="{Binding MaxNaturalGas}"/>

                <DataGridTextColumn Header="Кокс баз." Binding="{Binding BaseCoke}"/>
                <DataGridTextColumn Header="Экв. зам." Binding="{Binding CokeReplacementRatio}"/>

                <DataGridTextColumn Header="Чугун баз." Binding="{Binding BaseIronProduction}"/>
                <DataGridTextColumn Header="[S] баз." Binding="{Binding BaseSulfur}"/>

                <DataGridTextColumn Header="Чугун мин." Binding="{Binding MinIronProduction}" Foreground="DarkGreen"/>
                <DataGridTextColumn Header="Кокс макс." Binding="{Binding MaxCoke}" Foreground="DarkRed"/>

                <DataGridTextColumn Header="dP/dV" Binding="{Binding DeltaIronPerGas}"/>
                <DataGridTextColumn Header="dP/dK" Binding="{Binding DeltaIronPerCoke}"/>
                <DataGridTextColumn Header="dS/dV" Binding="{Binding DeltaSulfurPerGas}"/>
                <DataGridTextColumn Header="dS/dK" Binding="{Binding DeltaSulfurPerCoke}"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Margin="0,16,0,0">

            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                <TextBlock Text="Общие параметры цеха" FontSize="16" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,16,0"/>

                <TextBox Width="140" materialDesign:HintAssist.Hint="Стоймость газа (руб/м³)" 
                            Style="{StaticResource MaterialDesignFloatingHintTextBox}" Margin="0,0,16,0" FontSize="16" Text="{Binding GasPrice, UpdateSourceTrigger=PropertyChanged}"/>

                <TextBox Width="140" materialDesign:HintAssist.Hint="Стоймость кокса (руб/кг)" 
                            Style="{StaticResource MaterialDesignFloatingHintTextBox}" FontSize="16" Text="{Binding CokePrice, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal">
                <Button Content="Загрузить данные" 
                        Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,0,16,0" Command="{Binding LoadDataCommand}"/>

                <Button Content="Добавить печь" 
                        Style="{StaticResource MaterialDesignOutlinedButton}" 
                        Margin="0,0,16,0" Command="{Binding AddFurnaceCommand}"/>

                <Button Content="Удалить печь" 
                        Style="{StaticResource MaterialDesignOutlinedButton}" 
                        Foreground="DarkRed" BorderBrush="DarkRed"
                        Margin="0,0,16,0" Command="{Binding DeleteFurnaceCommand}"/>

                <Button Content="Рассчитать оптимизацию" 
                        Style="{StaticResource MaterialDesignRaisedButton}" Command="{Binding CalculateCommand}"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>